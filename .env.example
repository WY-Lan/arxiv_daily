# 阿里百炼 API 配置
# 请替换为您的实际 API Key
BAILIAN_API_KEY=your_bailian_api_key_here

# LLM Provider 设置
LLM_PROVIDER=bailian

# 模型选择
# 论文筛选模型（推荐 qwen-max）
MODEL_SELECTION=qwen-max
# 内容生成模型（推荐 qwen-max）
MODEL_SUMMARY=qwen-max
# 平台发布模型（推荐 qwen-plus，平衡性能和速度）
MODEL_PUBLISHER=qwen-plus

# 每日推送论文数量
DAILY_PAPER_COUNT=5

# 定时任务设置（默认每天9:00执行）
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0

# 数据库配置（默认使用 SQLite）
DATABASE_URL=sqlite+aiosqlite:///./storage/arxiv.db

# ============ 平台集成配置 ============

# Notion 配置
NOTION_API_KEY=your_notion_api_key
NOTION_DATABASE_ID=your_database_id
# 父页面ID（用于每日页面模式，将每日论文整合到一个页面）
NOTION_PARENT_PAGE_ID=your_parent_page_id

# 飞书配置
# 方式一：自定义机器人 Webhook（推荐，简单快速）
# 1. 在飞书群中添加自定义机器人
# 2. 复制 Webhook URL 填入下方
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# 方式二：企业自建应用（高级功能，需要管理员权限）
# FEISHU_APP_ID=your_feishu_app_id
# FEISHU_APP_SECRET=your_feishu_app_secret

# 小红书配置（第三方服务）
XHS_API_KEY=your_xhs_api_key
XHS_API_URL=your_xhs_api_url

# 微信公众号配置
WECHAT_APP_ID=your_wechat_appid
WECHAT_APP_SECRET=your_wechat_appsecret

# ============ 改进版筛选器配置 ============

# 全文内容分析（需要下载PDF，推荐启用）
ENABLE_FULL_PDF_ANALYSIS=true

# 作者历史质量分析（需要Semantic Scholar API Key）
ENABLE_AUTHOR_HISTORY_ANALYSIS=true

# 论文对比分析（与已有工作进行对比）
ENABLE_PAPER_COMPARISON=true

# 社交媒体监控（发现热点论文）
ENABLE_SOCIAL_MONITORING=true

# 社交媒体监控区域设置
# 可选值: "global" (国际平台) 或 "china" (国内平台)
# 如果部署在国内服务器，建议设为 "china"
SOCIAL_MEDIA_REGION=china

# 国内社交媒体监控（部署在国内时推荐）
ENABLE_CN_SOCIAL_MONITORING=true
CN_SOCIAL_SIGNAL_WEIGHT=0.15

# 小红书 Cookie（可选，用于监控小红书热点）
# 需要从浏览器开发者工具复制 Cookie
XIAOHONGSHU_COOKIE=

# 即刻 API Token（可选，需要申请）
JIKE_API_TOKEN=

# 微信公众号监控配置
# 数据源可选: "sogou" (搜狗微信搜索，免费但反爬严格) / "xinbang" (新榜API，付费但稳定) / "custom" (自定义)
WECHAT_MONITOR_SOURCE=sogou
ENABLE_WECHAT_MONITORING=true
WECHAT_SIGNAL_WEIGHT=0.15

# 新榜API Key（如使用新榜数据源）
XINBANG_API_KEY=

# ============ 国际社交媒体配置（可选，国内部署可能无法访问） ============

# Twitter API Token（国际平台，国内无法直接访问）
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# 社交媒体信号权重（0-1，建议0.1-0.2）
SOCIAL_SIGNAL_WEIGHT=0.15

# 论文年龄阈值（天数）
# 新论文（<30天）使用不同权重
PAPER_AGE_THRESHOLD_NEW=30

# ============ API Keys（可选）============

# Semantic Scholar API（获取引用数据和作者信息，可选但推荐）
SEMANTIC_SCHOLAR_API_KEY=your_s2_api_key